{
  "version": 2,
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/remoteEntry.js",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "no-cache"
      },
      "dest": "/remoteEntry.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
