# ─── Module Federation Remote URLs ───────────────────────────────────────────────

# Shell → Hitachi showcase remote URL.
# In development: leave empty (defaults to http://localhost:5001).
# In production: set to the Vercel URL of showcase-hitachi,
# e.g. https://anhdo-showcase-hitachi.vercel.app
NEXT_PUBLIC_HITACHI_REMOTE_URL=

# ─── CV Download (Vercel Blob) ───────────────────────────────────────────────────

# URL to the CV PDF hosted on Vercel Blob.
# Upload via Vercel Dashboard → Storage → Blob, then paste the URL here.
# When empty, the "Download CV" button shows "CV Coming Soon" instead.
NEXT_PUBLIC_CV_URL=
