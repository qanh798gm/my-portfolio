{
  "name": "@portfolio/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared React component library for the portfolio — atomic design, Storybook documented",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --watch --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rimraf dist storybook-static"
  },
  "dependencies": {
    "@portfolio/tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@portfolio/config": "workspace:*",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.3"
  }
}
